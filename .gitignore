# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# vercel workflow SDK auto-generated route handlers (rebuilt on `next dev` /
# `next build`; the source of truth is /src/workflows/*.workflow.ts)
/src/app/.well-known/workflow/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.vercel

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# memo
stale-ui-updates.md

#refs
/refs

# playwright
.playwright-mcp

# swc
/.swc

# scripts
/scripts
/data_migration

# data imports
/WhatsAppChatHistory
